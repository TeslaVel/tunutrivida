<div class="col-12 col-sm-12 col-md-9 col-lg-6 mx-auto">
	<% url = if editing
            patch_patient_path(@patient)
           else
            post_patients_path
           end
  %>
	<%= simple_form_for(@patient, url: url) do |f| %>
		<%= f.error_notification %>
		<%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

		<div class="card">
			<div class="card-header" style="background: transparent;">
					<h4 class="card-title"><%= t(title) %></h4>
			</div>
			<div class="card-body">
					<% if @patient.image.present? %>
						<div class="row py-2">
							<div class="col-sm-12">
								<div class="bg-transparent">
									<%= image_tag @patient.image, style: 'background-size: cover; background-position: center center; height: 250px; width: 100%;' %>
								</div>
							</div>
						</div>
					<% end %>
					<div class="row">
						<label class="col-sm-2 col-form-label"><%= t('.image')%></label>
						<div class="col-sm-7">
							<div class="form-group">
								<%= f.file_field :image %>
							</div>
						</div>
					</div>
					<div class="row">
						<label class="col-sm-2 col-form-label"><%= t('.first_name')%></label>
						<div class="col-sm-7">
								<div class="form-group">
								<%= f.input :first_name, label: false, input_html: { class: "form-control" } %>
								</div>
						</div>
					</div>
					<div class="row">
						<label class="col-sm-2 col-form-label"><%= t('.last_name') %></label>
						<div class="col-sm-7">
								<div class="form-group">
									<%= f.input :last_name, label: false, input_html: { class: "form-control" } %>
								</div>
						</div>
					</div>

				<div class="row">
						<label class="col-sm-2 col-form-label"><%= t('.date_of_birth') %></label>
						<div class="col-sm-7">
							<div class="select-date-wrapper custom-width">
								<%= f.date_select(:date_of_birth,
											options = { start_year: DateTime.now.year - 18, end_year: DateTime.now.year - 75, order: [ :day, :month, :year], include_blank: true},
											html_options = { class: 'select-date form-control'})%>
							</div>
						</div>
				</div>

				<div class="row">
					<label class="col-sm-2 col-form-label">Gender</label>
					<div class="col-sm-7">
							<%= f.input :gender_id, collection: @genders, label: false, value_method: :id, name: "Gender", include_blank: false, selected: @patient&.gender&.id, input_html: { class: "form-control"} %>
					</div>
				</div>

				<div class="row">
					<label class="col-sm-2 col-form-label">BMR Source</label>
					<div class="col-sm-7">
							<%= f.input :bmr_factor_source, collection: BmrFactor.distinct.select(:name, :source), label: false, value_method: :source, name: "bmr", include_blank: false, selected: @patient&.bmr_factor_source, input_html: { class: "form-control"} %>
					</div>
				</div>
			</div>
			<div class="card-footer text-center" style="background: transparent;">
					<%= f.button :submit , class: "btn btn-primary" %>
					<% if editing %>
						<%= link_to t('patients.back'), patient_path(@patient)%>
					<% else %>
						<%= link_to t('patients.back'), patients_path %>
					<% end %>
			</div>
		</div>
	<% end %>
</div>



