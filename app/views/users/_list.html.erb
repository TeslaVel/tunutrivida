<div class="col-12">
  <div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1><%= t(title) %></h1>
    <%= link_to t('patients.new_patient'), new_patient_path , class: "btn btn-primary" %>
  </div>

  <div style="flex-grow: 1;">
    <input type="text" id="searcher" placeholder="Search patient">
  </div>
  <div class="d-flex flex-column justify-content-between align-items-center">
    <div class="py-2" style="flex-grow: 1;">
      <%= render 'paginations/pagination', objectData: patients %>
    </div>
    <div class="table-responsive">
      <table class="table">
        <thead>
          <tr>
            <th>First name</th>
            <th>Last name</th>
            <th>Date of bird</th>
            <th>Gender</th>
            <th>Packages-Sessions</th>
            <th colspan="3" class="text-center">Actions</th>
          </tr>
        </thead>

        <tbody>
          <% patients.each do |patient| %>
            <tr>
              <td><%= link_to patient_path(patient.id) do %>
                  <%= patient.first_name %>
                <% end %></td>
              <td><%= patient.last_name %></td>
              <td><%= patient.date_of_birth %></td>
              <td><%= patient.gender.name %></td>
              <td><%= patient.sessions.count %></td>
              <td>
                <%= link_to patient_path(patient.id) do %>
                  <i class="fa fa-eye c-blue"></i>
                <% end %>
              </td>
          
              <td >
                <%= link_to patient_path(patient.id), method: :delete, data: { confirm: t('patients.are_you_sure') } do %>
                  <i class="fa fa-trash c-red"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="d-flex flex-column justify-content-center py-2">
      <%= render 'paginations/pagination', objectData: patients %>
    </div>
  </div>

</div>

