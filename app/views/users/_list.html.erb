<div class="col-12">
  <div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1><%= t(title) %></h1>
    <%= link_to t('patients.new_patient'), new_patient_path , class: "btn btn-primary" %>
  </div>

  <div style="flex-grow: 1;">
    <input type="text" id="searcher" placeholder="Search patient">
  </div>
  <div class="d-flex flex-column justify-content-between align-items-center">
    <div class="py-2" style="flex-grow: 1;">
      <%= render 'paginations/pagination', objectData: patients %>
    </div>
    <%= render Elements::TableComponent.new(
      row_fields: [
        { field: :first_name, link: ->(object) { link_to(object[:first_name], patient_path(object)) }},
        { field: :last_name },
        { field: :date_of_birth },
        { field: 'gender.name', label: 'Gender' },
        { field: 'sessions.count', label: 'Packages-Sessions' },
      ],
      row_objects: patients,
      table_alias: 'patient',
      # table_alias: patients.model.to_s.downcase,
      row_actions:  {
        edit: nil,
        # show: { with_icon: { name: 'eye' }, color_class: 'c-red', label: nil },
        # delete: { with_icon: { name: 'trash' }, color_class: 'c-red', label: nil, method: :delete,  data: { confirm: t('patients.are_you_sure') } }
      }
    )%>

    <div class="d-flex flex-column justify-content-center py-2">
      <%= render 'paginations/pagination', objectData: patients %>
    </div>
  </div>

</div>

