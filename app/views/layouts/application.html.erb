<!DOCTYPE html>
<html>
  <head>
    <title>Template</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <% if @prevent_caching %>
      <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate"/>
      <meta http-equiv="Pragma" content="no-cache"/>
      <meta http-equiv="Expires" content="0"/>
      <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">

    <% end %>
    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
    <%= action_cable_meta_tag %>
    <%= yield :javascript %>
  </head>

  <body id="page-top">
    <main id="wrapper" class="bg-secondary-01">

      <%= render Navigation::SidebarComponent.new(organization: @organization, device:) %>

      <section class="d-flex flex-column bg-white w-100">
        <%= render TopBar::TopBarComponent.new(current_user:) %>

        <section class=" mt-4 text-primary-200"
          style="height: calc(100vh - 172px); scroll-behavior: smooth; overflow: scroll; overflow-x: hidden;">
          <%= render Notifications::FlashComponent.new %>
          <%= yield %>
        </section>

        <footer class="sticky-footer bg-secondary-200 text-white-01">
          <%= render FooterComponent.new(text: 'TeslaDev All Rights Reserved') %>
        </footer>
      </section>
    </main>

    <!-- Scroll to Top Button-->
    <a class="scroll-to-top rounded" href="#page-top">
      <i class="fas fa-angle-up"></i>
    </a>

    <!-- Logout Modal-->
    <%= render Forms::ModalComponent.new(
      id_modal: 'logoutModal',
      title: 'Ready to Leave?',
      primary_actions: {
        component: Elements::LinkComponent.new(
          label: 'Logout',
          url: destroy_user_session_path,
          classes: 'btn btn-primary',
          action_method: 'delete'
        )
      }
    ) do %>
      <div class="modal-body">Select "Logout" below if you are ready to end your current session.</div>
    <% end %>
  </body>
</html>
