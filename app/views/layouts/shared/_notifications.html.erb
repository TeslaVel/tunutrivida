<li class="nav-item dropdown no-arrow mx-1">
  <a class="nav-link dropdown-toggle" href="#" id="alertsDropdown" 
    role="button" data-toggle="dropdown"aria-haspopup="true"
    aria-expanded="false">
    <i class="fas fa-bell fa-fw"></i>

    <!-- Counter - Alerts -->
      <span class="badge badge-danger badge-counter <%= 'd-none' if notifications.blank? %>" id="notification-counter">
        <%= notifications&.size %>+
      </span>
  </a>

  <!-- Dropdown - Alerts -->
  <div aria-labelledby="alertsDropdown"
    class="dropdown-list dropdown-menu dropdown-menu-right 
           shadow animated--grow-in">

    <h6 class="dropdown-header">
      Notifications Center
    </h6>

    <div id="notifications-container" class="h-300px overflow-hidden">
     <div class="h-100 overflow-y-scroll">
      <% notifications&.each do |notification| %>
        <% if notification&.associated_object&.entry.present? %>
          <a class="dropdown-item d-flex align-items-center" href="<%= entry_path(notification.associated_object.entry) %>">
        <% else %>
          <a class="dropdown-item d-flex align-items-center" href="">
        <% end %>
          <div class="mr-3">
            <div class="icon-circle bg-<%= notification.notification_type %>">
              <i class="fas fa-file-alt text-white"></i>
            </div>
          </div>
          <div>
            <div class="small text-gray-500"><%= notification.created_at.strftime('%b %-d at %I:%H %P') %></div>
            <% if notification.seen %>
              <%= notification.content %>
            <% else %>
              <span class="font-weight-bold"><%= notification.content %></span>
            <% end %>
          </div>
        </a>
      <% end %>
     </div>
    </div>

    <a class="dropdown-item text-center small text-gray-500" href="#">
      Show All Notifications
    </a>
  </div>
</li>