<div class="card shadow mb-4">
  <a href="#collapseCardExample_2" class="d-block card-header py-3 <%= expanded ? '' : 'collapsed' %>" data-toggle="collapse" role="button" aria-expanded="<%= expanded %>" aria-controls="collapseCardExample_2">
    <h6 class="m-0 font-weight-bold text-primary"><%= title %> (<%= billing_items.count %>)</h6>
  </a>
  <div class="collapse <%= expanded ? 'show' : '' %>" id="collapseCardExample_2">
    <div class="py-2 px-2 d-flex justify-content-end">
      <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#exampleModalCenter">
        <%= t('billings.new_item') %>
      </button>
    </div>

    <% if billing_items.present? %>
      <div class="card-body">
        <div class="table-responsive">
          <!-- id="dataTable" -->
          <table class="table table-bordered" width="100%" cellspacing="0">
            <thead>
              <tr>
                <th></th>
                <th>Type</th>
                <th><%= t('billings.description') %></th>
                <th class="text-center"><%= t('billings.amount') %></th>
                 <th class="text-center"><%= t('billings.quantity') %></th>
                <th class="text-center">Total</th>
                <th class="text-center">...</th>
              </tr>
            </thead>
            <!-- <tfoot>
              <tr>
                <th>Name</th>
                <th>Price</th>
                <th>Description</th>
              </tr>
            </tfoot> -->
            <tbody id='billing_items_table_body'>
             	<% billing_items.each do |item| %>
              <tr>
                <th class="text-center"><%= check_box_tag(:item_ids, item.id, false, class: 'checkbox_item_ids') %></th>
                <td><%= item.item_type %></td>
                <td><%= item.description %></td>
                <td class="text-center">
                  <%= "#{@gbl_configuration.currency_code} #{item.amount}" %> |
                  <%= "#{item.target_currency_code} #{(item.amount * item.target_conversion).round(2) }" %>
                </td>
                <td class="text-center"><%= item.quantity %></td>
                <td class="text-center">
                  <%= "#{@gbl_configuration.currency_code} #{item.total}" %> |
                  <%= "#{item.target_currency_code} #{(item.total * item.target_conversion).round(2) }" %>
                </td>
                <td class="text-center">
                  <%= link_to t('billing_items.delete'), billing_items_destroy_path(billing, item), method: :delete, data: { confirm: 'Are you sure?' }, class: "destroy_item", :remote => true %>
                </td>
              </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="py-2 px-4 d-flex justify-content-end">
        <button class="btn btn-success" id='btn-create-payment' onclick="add_paid_item()"><%= t('payments.create') %></button>
      </div>

    <% end %>
  </div>
</div>


<!-- Modal -->
<div class="modal fade" id="exampleModalCenter" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="exampleModalLongTitle">Add Item</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <%= form_with scope: BillingItem.new, url: billing_items_create_path(billing), data: { type: :json }, html: {id:"billing_item_form_id", class: 'billing_item_form', multipart: true, remote: true} do |f| %>
          <div class="form-group">
            <label for="billing_type_item_type">Type</label>
            <%= f.select(:item_type, options_for_select((BillingItem::ItemTypes || []).map {|k| [k.to_s.humanize, k]}, :selected => nil ), {}, {:required => true ,:class => 'form-control'}) %>
          </div> 

          <div class="form-group to-hide" style="display: none;">
            <label for="patient_package_id">Package</label>
            <%= f.select(:patient_package_id, options_for_select(patient_packages.map {|k| [k.name.to_s.humanize, k.id]}, :selected => nil ), {}, {:required => true ,:class => 'form-control package'}) %>
          </div>

          <div class="form-group to-hide" style="display: none;">
            <label for="product_id">Product</label>
            <%= f.select(:product_id, options_for_select(products.map {|k| [k.name.to_s.humanize, k.id]}, :selected => nil ), {}, {:required => true ,:class => 'form-control product'}) %>
          </div>

          <div class="form-group to-hide" style="display: none;">
            <label for="quantity">Quantity</label>
            <%= f.text_field :quantity, label: t('.quantity'), class: "form-control quantity" %>
          </div>

          <div class="form-group to-hide" style="display: none;">
            <label for="discount_id">Discount</label>
            <%= f.select(:discount_id, options_for_select(discounts.map {|k| [k.name.to_s.humanize, k.id]}, :selected => nil ), {}, {:required => true ,:class => 'form-control discount'}) %>
          </div>

          <div class="form-group to-hide" style="display: none;">
            <label for="description">Description</label>
            <%= f.text_field :description, label: t('.description'), class: "form-control" %>
          </div>

        <% end %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
        <button type="button" class="btn btn-primary" onclick="add_billing_item()">Add Item</button>
      </div>
    </div>
  </div>
</div>
