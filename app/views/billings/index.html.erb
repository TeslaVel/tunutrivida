<h1>Billings</h1>
<div class="w-100 text-right mb-4">
  <%= link_to t('billings.new_billing'), new_billing_path , class: "btn btn-primary" %>
</div>
<table class="table">
  <thead>
    <tr>
      <th>Code</th>
      <th>Description</th>
      <th>Patient</th>
      <th>Pending</th>
      <th>Paid</th>
      <th class="text-center">Actions</th>
    </tr>
  </thead>

  <tbody>
    <% @billings.each do |billing| %>
      <tr>
        <td><%= link_to billing.code, billing %></td>
        <td><%= billing.description %></td>
        <td><%= billing.patient.first_name %></td>
        <td><%= billing&.billing_items.inprocess.sum(:total).to_f || 0 %></td>
        <td><%= billing&.billing_items.processed.sum(:total).to_f || 0 %></td>
        <td class="text-center"><%= link_to t('billings.delete'), billing, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>


