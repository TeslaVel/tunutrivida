"<% @patient = @billing.patient %>"

"<% used_package_ids = @billing.billing_items.where(itemable_type: 'Package').pluck(:itemable_id) %>"
"<% used_product_ids= @billing.billing_items.where(itemable_type: 'Product').pluck(:itemable_id)%>"
"<% used_discount_ids = @billing.billing_items.where(itemable_type: 'Discount').pluck(:itemable_id)%>"

"<% @patient_packages = @patient.packages.where.not(id: used_package_ids) %>"
"<% @products = Product.where.not(id: used_product_ids) %>"
"<% @discounts = Discount.where.not(id: used_discount_ids ) %>"


$('#exampleModalCenter').removeClass('show').css('display', 'none')
$('.modal-backdrop').remove()


$('#billing_pending_total_display').text("<%= @billing.billing_items.inprocess.sum(:total).to_f%>");
$('#billing_total_display').text("<%= @billing.billing_items.processed.sum(:total).to_f%>");

$("#billing_items_partial").html("\
		<%= escape_javascript(render(:partial => 'billings/billing_items', :locals => {\
																 :key => '2',\
																 :expanded => true,\
																 :billing => @billing,\
																 :patient_packages => @patient_packages,\
															   :billing_items => @billing.billing_items.inprocess,\
															   :products => @products,\
															   :discounts => @discounts,\
															   :title => 'Pending to pay'} )) %>");


$("#paid_items_partial").html("\
		<%= escape_javascript(render(:partial => 'billings/paid_items', :locals => {\
																 :key => '2',\
																 :expanded => true,\
															   :payments => @billing.payments,\
															   :title => 'Paid Items'} )) %>");

