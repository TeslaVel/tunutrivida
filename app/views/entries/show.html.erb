<div class="d-flex justify-content-center">
  <div class="col-sm-12 col-md-6">
    <div class="d-sm-flex col-sm-12 align-items-center justify-content-between mb-4">
      <span class="h3 mb-0 text-darsk"></span>
       <%= link_to 'Back', entries_path %>
    </div>

    <div class="col-sm-12 col-md-12 mb-4">
      <div class="card col-sm-12">
        <div class="card-header bg-transparent d-flex justify-content-between align-items-center px-2">
          <div><%= @entry.entry_type %></div>
          <span class="">
            <%= link_to 'Edit', edit_entry_path(@entry) %>
          </span>
        </div>
        <div class="card-body tab-content px-2">
          <div class="col-md-10 p-0">
            <p class="mb-2 "><%= @entry.description %></p>
          </div>
        </div>
      </div>
      <hr />
      <div class="card">
        <div class="card-body">
          <%= simple_form_for([@entry, Comment.new]) do |f| %>
            <%= f.input :message, label: false, placeholder: 'Leave a comment', input_html: { class: 'form-control' } %>
            <%= f.button :submit, class: 'btn btn-primary mt-2' %>
          <% end %>
        </div>
      </div>

      <hr />

      <% @entry.comments.map do |comment| %>
        <div class="card pb-3">
          <div class="card-header bg-transparent">
            <%= comment.user.full_name %>
          </div>
          <div class="card-body">
            <%= comment.message %>
          </div>
        </div>
      <% end %>


    </div>
  </div>
</div>
