<%= link_to 'Back', entries_path %>
<div class="d-flex justify-content-center">
  <div class="col-sm-12 col-md-12 col-lg-8 col-xl-6 p-0 mb-5">
    <div class="card p-0">
      <div class="card-header bg-pink-300 color-pink-100 d-flex justify-content-between align-items-center px-0 py-2">
        <div class="px-2"><img src="" alt="profile" tile="profile"></div>
        <div class="d-flex flex-column flex-grow-1 px-2">
          <span><%= @entry.poster.first_name %></span>
          <span><%= @entry.created_at.strftime('%b %-d at %I:%P') %></span>
          <span class="font-size-12"><%= @entry.entry_type %></span>
        </div>
        <div class="px-2">
          <%= link_to 'Edit', edit_entry_path(@entry) , class: 'color-pink-100' %>
        </div>
      </div>
      <div class="p-0 py-2 d-flex justify-content-center bg-primary-50 border-primary-100 ">
        <div class="d-flex pl-2 flex-column">
          <span class="d-flex"><p class="m-0">-&nbsp;<%= @entry.description %>&nbsp;-</p></span>
          <span class="f-size-12"><%= @entry.created_at.strftime('%b %-d at %I:%P') %></span>
        </div>
      </div>
      <div class="card-body px-0 pt-0 h-300px overflow-hidden">
        <div class="px-3 h-100 overflow-y-scroll">
          <div id="comments_partial">
            <%= render 'comments', comments: @comments %>
          </div>
        </div>
      </div>
      <div class="px-2 py-2">
        <div class="d-flex justify-content-end mb-2">
          <%= form_with scope: Comment.new, url: entry_comments_path(@entry),
            data: { type: :json },
            html: {
              id:"reaction_form",
              class: 'reaction_form bg-pink-100 border-radius-40 d-flex justify-content-center px-2',
              multipart: true, remote: true
            } do |f| %>
            <%= f.hidden_field :message, id: "input_emoji" %>
            <%= f.hidden_field :comment_tpe, value: 'reaction', id: "input_reaction" %>
            <span class="p-0 m-0" id="emojis_partial">
              <%= render 'emojis' %>
            </span>
          <% end %>
        </div>

        <%= simple_form_for([@entry, Comment.new],
          html: {
            class: 'd-flex',
            id:"comment_form",
            remote: true
          }) do |f| %>
          <div class="col-10 p-0">
            <textarea
              class="text required form-control border-radius-40"
              placeholder="Leave a comment"
              name="comment[message]"
              id="comment_message"
              cols="30" rows="1" style="overflow: hidden;"></textarea>
          </div>
          <div class="col-2 p-0 text-right">
          <input type="submit"
            name="commit"
            onclick="addComment(event)"
            value="Crear"
            class="btn bg-primary-500 color-gray-50 border-radius-40"
            id="create_comment_button"
            data-disable-with="Crear">
          </div>
        <% end %>
      </div>
    </div>
    <hr />
  </div>
</div>

<% content_for :javascript do %>
  <script>
    //******************
    //* Create billing item
    //*
    function addReaction(event) {
        event.preventDefault();

        $("#input_emoji").val(event.target.value);
        let dataToSubmit = $("#reaction_form").serialize();

        $.ajax({
          url: $("#reaction_form").attr('action'),
          type: "POST",
          data: dataToSubmit,
          dataType: "script",
          success: function(data) {},
          error: function(err) {
            console.log('err', err);
          }
        })
    }

    function addComment(event) {
        event.preventDefault();
        let dataToSubmit = $("#comment_form").serialize();
        $.ajax({
          url: $("#comment_form").attr('action'),
          type: "POST",
          data: dataToSubmit,
          dataType: "script",
          success: function(data) {$("#comment_message").val('')},
          error: function(err) {
            console.log('err', err);
          }
        })
    }
  </script>
<% end %>