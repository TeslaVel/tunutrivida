<div class="col-12 col-md-6 mx-auto">
    <div class="d-flex col-12 align-items-center justify-content-between mb-4">
      <span class="h3 mb-0 text-darsk">[Meal info]</span>
       <%= link_to 'Back', meals_path %>
    </div>

    <div class="col-12 mb-4">
      <div class="card col-sm-12">
        <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
          <ul class="nav nav-tabs card-header-tabs">
            <li class="nav-item">
              <a class="nav-link active" href="#about" data-toggle="tab">Info</a>
            </li>
          </ul>
          <span class="">
            <%= link_to 'Edit', edit_meal_path(@meal) %>
          </span>
        </div>
        <div class="card-body tab-content">
          <div class="tab-pane active" id="about">
            <div class="row">
              <div class="col-md-2 p-0">
                <div class="list-unstyled">
                  <p class="mb-2 text-left">Title:</p>
                  <p class="mb-2 text-left">Type:</p>
                </div>
              </div>
              <div class="col-md-10 p-0">
                <div class="list-unstyled">
                  <p class="mb-2 "><%= @meal.name %></p>
                  <p class="mb-2 "><%= @meal.meal_type %></p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
</div>
