<div class="card shadow mb-4" id="inside_partial">
  <a href="#collapseCardExample_<%= key %>" class="d-block card-header py-2 <%= expanded ? '' : 'collapsed' %>" data-toggle="collapse" role="button" aria-expanded="<%= expanded %>" aria-controls="collapseCardExample_<%= key %>">
    <h6 class="m-0 font-weight-bold text-primary text-center"><%= title %></h6>
  </a>

  <% if defined? show_sub_header_edit %>
    <div class="d-flex justify-content-end py-3 px-3" style="gap: 8px;">
      <%= link_to 'Edit', edit_diet_path(diet), class: 'btn btn-primary' %>
    </div>
  <% end %>

  <div class="collapse <%= expanded ? 'show' : '' %>" id="collapseCardExample_<%= key %>">
    <% if diet.diet_meal_weeks.present? %>
      <div class="card-body p-2" style="overflow-x: scroll; white-space: nowrap;">
        <div class="grid-container" style="width: 900px;">
            <div style="grid-template-columns: repeat(7, 200px); grid-template-rows: 45px; display: grid; column-gap: 4px;">
              <% diet.diet_meal_weeks.each do |dmw| %>
                <div class=" text-center border pt-2">
                  <strong><%= t(dmw.day_of_week) %></strong>
                </div>
              <% end %>
            </div>
            <div style="grid-template-columns: repeat(7, 200px); column-gap: 4px; row-gap: 15px;display: grid;">
              <% diet.diet_meal_weeks.each do |dmw| %>
                  <div style="white-space: normal; white-space: normal;display: flex;flex-direction: column;justify-content: space-between;gap: 5px;" >
                    <% dmw.diet_meal_times.each do |dmt| %>
                      <div class="border" style="min-height: 150px;">
                        <strong class="text-center"><%= t(dmt.meal_time) %>:</strong>
                        <div class="ml-0"><%= dmt.diet_ingredient.meal.name %></div>
                        <small class="ml-1" style="color: gray"><%= dmt.diet_ingredient.instructions %></small>
                      </div>
                    <% end %>
                  </div>
              <% end %>
            </div>
        </div>
      </div>
    <% end %>
  </div>
</div>