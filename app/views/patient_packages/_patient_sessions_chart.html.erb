<div class="card shadow mb-4" id="patient_graph_bar" onload="()">
    <% unless hide_header %>
      <div class="card-header">
        <%= t(title) %>
      </div>
    <% end %>
    <div class="card-body">
      <div class="chart-bar">
        <canvas id="<%= id %>"></canvas>
      </div>
      <hr>
    </div>
</div>