<h1>Genders</h1>

<table class="table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Description</th>
      <th colspan="3">Actions</th>
    </tr>
  </thead>

  <tbody>
    <% @genders.each do |gender| %>
      <tr>
        <td><%= gender.name %></td>
        <td><%= gender.description %></td>
        <td><%= link_to t('genders.show'), gender %></td>
        <td><%= link_to t('genders.edit'), edit_gender_path(gender) %></td>
        <td><%= link_to t('genders.delete'), gender, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to t('genders.new_gender'), new_gender_path , class: "btn btn-primary" %>
