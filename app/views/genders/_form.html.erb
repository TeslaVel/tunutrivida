<div class="row w-40 m-auto">
  <%= simple_form_for(@gender) do |f| %>
    <h1><%= t(title) %></h1>

    <%= f.error_notification %>
    <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

    <div class="form-group">
      <%= f.input :name, label: t('.name'), input_html: { class: "form-control" } %>
    </div>
    <div class="form-group">
      <%= f.input :description, label: t('.description'), input_html: { class: "form-control" } %>
    </div>

    <div class="form-actions">
      <%= f.button :submit, t(action_button), class: "btn btn-primary" %>
      <%= link_to t('genders.back'), genders_path %>
    </div>
  <% end %>
</div>